MATCH (p:Product {sku: 'SKU-0036'}), (ph:Phase) WHERE ph.name = 'Cleansing Phase' AND NOT EXISTS { MATCH (ph)<-[:CONTAINS]-() } CREATE (p)-[:CONTAINS {ratio: 0.221824}]->(ph);
MATCH (ph:Phase {name: 'Cleansing Phase'})<-[:CONTAINS]-({sku: 'SKU-0036'}), (i:Ingredient {name: 'Decyl Glucoside'}) CREATE (ph)-[:CONTAINS {ratio: 0.548759}]->(i);
MATCH (ph:Phase {name: 'Cleansing Phase'})<-[:CONTAINS]-({sku: 'SKU-0036'}), (i:Ingredient {name: 'Sodium Lauryl Sulfate'}) CREATE (ph)-[:CONTAINS {ratio: 0.313798}]->(i);
MATCH (ph:Phase {name: 'Cleansing Phase'})<-[:CONTAINS]-({sku: 'SKU-0036'}), (i:Ingredient {name: 'Pentylene Glycol'}) CREATE (ph)-[:CONTAINS {ratio: 0.137444}]->(i);
CREATE (:Phase {name: 'Soothing Phase'});
MATCH (p:Product {sku: 'SKU-0036'}), (ph:Phase) WHERE ph.name = 'Soothing Phase' AND NOT EXISTS { MATCH (ph)<-[:CONTAINS]-() } CREATE (p)-[:CONTAINS {ratio: 0.04498}]->(ph);
MATCH (ph:Phase {name: 'Soothing Phase'})<-[:CONTAINS]-({sku: 'SKU-0036'}), (i:Ingredient {name: 'Moringa Oil'}) CREATE (ph)-[:CONTAINS {ratio: 0.592587}]->(i);
MATCH (ph:Phase {name: 'Soothing Phase'})<-[:CONTAINS]-({sku: 'SKU-0036'}), (i:Ingredient {name: 'Niacinamide'}) CREATE (ph)-[:CONTAINS {ratio: 0.407413}]->(i);

// ============================================================
// Step 12: Create Ontology and SHACL nodes
// ============================================================
CREATE (:Ontology {name: 'cosmo', turtle: '@prefix cosmo: <http://example.org/cosmo#> .\n@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .\n@prefix owl: <http://www.w3.org/2002/07/owl#> .\n@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .\n\n# Class hierarchy\ncosmo:CosmeticIngredient a owl:Class .\n\ncosmo:AHAExfoliant a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:Adaptogen a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:Aldehyde a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:Allergen a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:AminoAcidDerivative a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:AmphotericSurfactant a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:AnionicSurfactant a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:AntiInflammatory a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:AntiMicrobial a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:AntiWrinkle a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:Antimicrobial a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:Antioxidant a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:AromaticAlcohol a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:Astringent a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:BHAExfoliant a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:BarrierRepair a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:Biopolymer a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:Carotenoid a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:CelluloseDerivative a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:Ceramide a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:ChemicalFilter a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:CollagenBooster a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:Emollient a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:Emulsifier a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:Enzyme a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:Ester a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:FattyAcid a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:FattyAlcohol a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:FragranceComponent a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:GlycolEther a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:Humectant a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:Hydrocarbon a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:InorganicAgent a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:IrritantRisk a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:Keratolytic a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:Lactone a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:Meroterpene a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:MineralFilter a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:NeurotransmitterInhibitor a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:NonionicSurfactant a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:OilSoluble a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:OrganicSalt a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:Paraben a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:Peptide a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:Phenol a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:PhenolicAcid a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:Phospholipid a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:PhotosensitiveAgent a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:PhotounstableAgent a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:PlantButter a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:PlantExtract a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:PlantOil a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:Polyol a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:Polyphenol a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:Polysaccharide a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:Preservative a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:Quinone a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:RetinoidAgent a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:RetinoidAlternative a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:RheologyModifier a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:Saccharide a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:Sesquiterpene a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:SignalPeptide a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:Silicone a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:SkinBrightener a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:Soothing a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:Sphingolipid a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:Sterol a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:SulfurCompound a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:Surfactant a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:SyntheticPolymer a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:Terpene a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:Thickener a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:Triglyceride a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:UVFilter a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:VitaminADerivative a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:VitaminB3Derivative a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:VitaminB5Derivative a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:VitaminB6Derivative a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:VitaminB7Derivative a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:VitaminCDerivative a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:VitaminDerivative a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:VitaminEDerivative a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:VitaminKDerivative a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:WaterSoluble a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:WaxEster a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:WoundHealingAgent a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:pHAdjuster a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:pHSensitiveAgent a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\n\n# Properties\ncosmo:maxConcentrationEU a owl:DatatypeProperty ; rdfs:domain cosmo:CosmeticIngredient ; rdfs:range xsd:double .\ncosmo:maxConcentrationUS a owl:DatatypeProperty ; rdfs:domain cosmo:CosmeticIngredient ; rdfs:range xsd:double .\ncosmo:maxConcentrationChina a owl:DatatypeProperty ; rdfs:domain cosmo:CosmeticIngredient ; rdfs:range xsd:double .\ncosmo:maxConcentrationJapan a owl:DatatypeProperty ; rdfs:domain cosmo:CosmeticIngredient ; rdfs:range xsd:double .\ncosmo:inciName a owl:DatatypeProperty ; rdfs:domain cosmo:CosmeticIngredient ; rdfs:range xsd:string .\ncosmo:casNumber a owl:DatatypeProperty ; rdfs:domain cosmo:CosmeticIngredient ; rdfs:range xsd:string .\n\n# Key axioms for reasoning\ncosmo:PhotosensitiveAgent a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:IrritantRisk a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:Allergen a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:pHSensitiveAgent a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:Keratolytic a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\n\n# Regulatory classification rules\ncosmo:RegulatedIngredient a owl:Class ; rdfs:subClassOf cosmo:CosmeticIngredient .\ncosmo:StrictlyRegulatedIngredient a owl:Class ; rdfs:subClassOf cosmo:RegulatedIngredient .'});
CREATE (:SHACLRules {name: 'cosmo_validation', turtle: '@prefix sh: <http://www.w3.org/ns/shacl#> .\n@prefix cosmo: <http://example.org/cosmo#> .\n@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .\n@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .\n\n# EU Regulatory Shapes\ncosmo:EURetinoidShape a sh:NodeShape ;\n    sh:targetClass cosmo:RetinoidAgent ;\n    sh:property [\n        sh:path cosmo:maxConcentrationEU ;\n        sh:maxCount 1 ;\n        sh:datatype xsd:double ;\n        sh:message "EU: Retinoid concentration limit must be declared" ;\n    ] .\n\ncosmo:EUPreservativeShape a sh:NodeShape ;\n    sh:targetClass cosmo:Preservative ;\n    sh:property [\n        sh:path cosmo:maxConcentrationEU ;\n        sh:maxCount 1 ;\n        sh:datatype xsd:double ;\n        sh:message "EU: Preservative concentration limit must be declared" ;\n    ] .\n\ncosmo:AllergenShape a sh:NodeShape ;\n    sh:targetClass cosmo:Allergen ;\n    sh:property [\n        sh:path cosmo:maxConcentrationEU ;\n        sh:minCount 1 ;\n        sh:message "EU: Allergens must declare concentration limits" ;\n    ] .\n\n# US Regulatory Shapes\ncosmo:USUVFilterShape a sh:NodeShape ;\n    sh:targetClass cosmo:UVFilter ;\n    sh:property [\n        sh:path cosmo:maxConcentrationUS ;\n        sh:maxCount 1 ;\n        sh:message "US: UV Filter concentration limit must be declared" ;\n    ] .\n\ncosmo:USPreservativeShape a sh:NodeShape ;\n    sh:targetClass cosmo:Preservative ;\n    sh:property [\n        sh:path cosmo:maxConcentrationUS ;\n        sh:maxCount 1 ;\n        sh:message "US: Preservative concentration limit must be declared" ;\n    ] .\n\n# China Regulatory Shapes\ncosmo:ChinaRetinoidShape a sh:NodeShape ;\n    sh:targetClass cosmo:RetinoidAgent ;\n    sh:property [\n        sh:path cosmo:maxConcentrationChina ;\n        sh:maxCount 1 ;\n        sh:message "China: Retinoid concentration limit must be declared" ;\n    ] .\n\ncosmo:ChinaExfoliantShape a sh:NodeShape ;\n    sh:targetClass cosmo:AHAExfoliant ;\n    sh:property [\n        sh:path cosmo:maxConcentrationChina ;\n        sh:maxCount 1 ;\n        sh:message "China: AHA Exfoliant concentration limit must be declared" ;\n    ] .\n\n# Japan Regulatory Shapes\ncosmo:JapanRetinoidShape a sh:NodeShape ;\n    sh:targetClass cosmo:RetinoidAgent ;\n    sh:property [\n        sh:path cosmo:maxConcentrationJapan ;\n        sh:maxCount 1 ;\n        sh:message "Japan: Retinoid concentration limit must be declared" ;\n    ] .\n\ncosmo:JapanPreservativeShape a sh:NodeShape ;\n    sh:targetClass cosmo:Preservative ;\n    sh:property [\n        sh:path cosmo:maxConcentrationJapan ;\n        sh:maxCount 1 ;\n        sh:message "Japan: Preservative concentration limit must be declared" ;\n    ] .\n\ncosmo:EUConcentrationLimitShape a sh:NodeShape ;\n    sh:targetClass cosmo:CosmeticIngredient ;\n    sh:sparql [\n        a sh:SPARQLConstraint ;\n        sh:message "EU concentration limit exceeded: {?this} has {?actual} but limit is {?limit}" ;\n        sh:select "PREFIX cosmo: <http://example.org/cosmo#> PREFIX xsd: <http://www.w3.org/2001/XMLSchema#> SELECT $this ?actual ?limit WHERE { $this cosmo:actualConcentration ?actual . $this cosmo:maxConcentrationEU ?limit . FILTER(xsd:double(?actual) > xsd:double(?limit)) }" ;\n    ] .\n\ncosmo:USConcentrationLimitShape a sh:NodeShape ;\n    sh:targetClass cosmo:CosmeticIngredient ;\n    sh:sparql [\n        a sh:SPARQLConstraint ;\n        sh:message "US concentration limit exceeded: {?this} has {?actual} but limit is {?limit}" ;\n        sh:select "PREFIX cosmo: <http://example.org/cosmo#> PREFIX xsd: <http://www.w3.org/2001/XMLSchema#> SELECT $this ?actual ?limit WHERE { $this cosmo:actualConcentration ?actual . $this cosmo:maxConcentrationUS ?limit . FILTER(xsd:double(?actual) > xsd:double(?limit)) }" ;\n    ] .\n\ncosmo:ChinaConcentrationLimitShape a sh:NodeShape ;\n    sh:targetClass cosmo:CosmeticIngredient ;\n    sh:sparql [\n        a sh:SPARQLConstraint ;\n        sh:message "China concentration limit exceeded: {?this} has {?actual} but limit is {?limit}" ;\n        sh:select "PREFIX cosmo: <http://example.org/cosmo#> PREFIX xsd: <http://www.w3.org/2001/XMLSchema#> SELECT $this ?actual ?limit WHERE { $this cosmo:actualConcentration ?actual . $this cosmo:maxConcentrationChina ?limit . FILTER(xsd:double(?actual) > xsd:double(?limit)) }" ;\n    ] .\n\ncosmo:JapanConcentrationLimitShape a sh:NodeShape ;\n    sh:targetClass cosmo:CosmeticIngredient ;\n    sh:sparql [\n        a sh:SPARQLConstraint ;\n        sh:message "Japan concentration limit exceeded: {?this} has {?actual} but limit is {?limit}" ;\n        sh:select "PREFIX cosmo: <http://example.org/cosmo#> PREFIX xsd: <http://www.w3.org/2001/XMLSchema#> SELECT $this ?actual ?limit WHERE { $this cosmo:actualConcentration ?actual . $this cosmo:maxConcentrationJapan ?limit . FILTER(xsd:double(?actual) > xsd:double(?limit)) }" ;\n    ] .\n'});

// ============================================================
// Step 13: Create ingredient mapping Template node
// ============================================================
CREATE (:Template {name: 'ingredient_mapping', template: '{"subject":"http://example.org/cosmo#{safeName}","triples":[{"predicate":"http://www.w3.org/1999/02/22-rdf-syntax-ns#type","object":"http://example.org/cosmo#{rdfClass}","kind":"iri"},{"predicate":"http://www.w3.org/2000/01/rdf-schema#label","object":"{name}"},{"predicate":"http://example.org/cosmo#inciName","object":"{inci}"},{"predicate":"http://example.org/cosmo#casNumber","object":"{cas}"},{"predicate":"http://example.org/cosmo#maxConcentrationEU","object":"{maxConcentrationEU}","datatype":"http://www.w3.org/2001/XMLSchema#double"},{"predicate":"http://example.org/cosmo#maxConcentrationUS","object":"{maxConcentrationUS}","datatype":"http://www.w3.org/2001/XMLSchema#double"},{"predicate":"http://example.org/cosmo#maxConcentrationChina","object":"{maxConcentrationChina}","datatype":"http://www.w3.org/2001/XMLSchema#double"},{"predicate":"http://example.org/cosmo#maxConcentrationJapan","object":"{maxConcentrationJapan}","datatype":"http://www.w3.org/2001/XMLSchema#double"}]}'});
